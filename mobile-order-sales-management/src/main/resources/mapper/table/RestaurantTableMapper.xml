<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.portfolio.mobileorder.table.mapper.RestaurantTableMapper">
    <resultMap id="RestaurantTableResultMap" type="com.portfolio.mobileorder.table.model.RestaurantTable">
        <id property="id" column="id"/>
        <result property="storeId" column="store_id"/>
        <result property="tableNumber" column="table_number"/>
        <result property="tableStatus" column="status"/>
        <result property="qrToken" column="qr_token"/>
        <result property="createdAt" column="created_at"/>
        <result property="createdBy" column="created_by"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="updatedBy" column="updated_by"/>
        <result property="deletedAt" column="deleted_at"/>
        <result property="tableVersion" column="version"/>
    </resultMap>

    <select id="findById" resultMap="RestaurantTableResultMap">
        SELECT
            id,
            store_id,
            table_number,
            status,
            qr_token,
            created_at,
            created_by,
            updated_at,
            updated_by,
            deleted_at,
            version
        FROM
            restaurant_tables
        WHERE
            id = #{id}
            AND deleted_at IS NULL
    </select>

    <update id="updateStatus">
        UPDATE
            restaurant_tables
        SET
            status = #{status},
            updated_at = #{updatedAt},
            updated_by = #{updatedBy},
            version = version + 1
        WHERE
            id = #{id}
            AND version = #{version}
            AND deleted_at IS NULL
    </update>

</mapper>
